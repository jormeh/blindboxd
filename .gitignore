# Ignore node_modules (already included)
node_modules

# Ignore build output (e.g., Vite or other bundlers)
dist/
build/

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment files (if you use them for secrets or configuration)
.env
.env.local
.env.*.local

# Ignore system files
.DS_Store
Thumbs.db

# Ignore IDE/editor-specific files
.vscode/
.idea/
*.swp
*.swo

# Ignore Chrome Extension-specific files
*.pem  # Private keys (if you generate a key for your extension)