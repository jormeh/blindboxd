{
	"name": "No Groupthink",
	"description": "A lightweight Chrome extension for Letterboxd that hides movie ratings and averages to help you form your own opinions.",
	"manifest_version": 3,
	"version": "1.0",
	"action": {
		"default_popup": "popup/popup.html",
		"default_title": "Toggle site style"
	},
	"icons": {
		"48": "icons/icon48.png"
	},
	"permissions": ["storage", "scripting", "activeTab"],
	"host_permissions": ["*://www.letterboxd.com/*"],
	"background": {
		"service_worker": "background.js"
	}
}
